import { redis } from '../lib/db';

export const prerender = false;

// If it's a POST request, save the progress state in the database
if (Astro.request.method === "POST") {
    try {
        const bodyStr = await Astro.request.text();
        const bodyJson = JSON.parse(bodyStr);
        // Insert or Update the JSON state
        await redis.set('checklist_progress', JSON.stringify(bodyJson));
        return new Response(JSON.stringify({ success: true }));
    } catch (e) {
        return new Response(JSON.stringify({ success: false }), { status: 500 });
    }
}

// Otherwise, GET the progress state
let serverStateStr = '{}';
try {
    const data = await redis.get<string>('checklist_progress');
    if (data) {
        serverStateStr = typeof data === 'string' ? data : JSON.stringify(data);
    }
} catch (e) {
    console.error("Could not fetch from Upstash:", e);
}
