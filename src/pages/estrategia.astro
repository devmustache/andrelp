<script define:vars={{ initialServerStateStr: serverStateStr }}>
const SK='dd_os_v2';
let serverState = {};
try {
  serverState = JSON.parse(initialServerStateStr || '{}');
} catch(e) {}


function load(){
  return serverState || {};
}

function save(s){
  serverState = s;
  // Make a background request to save in SQLite.
  fetch(window.location.href, {
    method: 'POST',
    body: JSON.stringify(s)
  }).catch(e => console.error("Could not save to db: ", e));
  // optionally, save locally as fallback
  try{localStorage.setItem(SK,JSON.stringify(s))}catch(e){}
}

function tog(id){
  const b=document.getElementById('b-'+id);
  const c=document.getElementById(id);
  const btn=c.querySelector('.tog');
  const isOpen=b.classList.contains('open');
  document.querySelectorAll('.tb.open').forEach(x=>x.classList.remove('open'));
  document.querySelectorAll('.tog').forEach(x=>x.textContent='Abrir');
  if(!isOpen){b.classList.add('open');btn.textContent='Fechar'}
}

function chk(id){
  const c=document.getElementById(id);
  const done=c.classList.toggle('done');
  const s=load();s[id]=done;save(s);
  upNav(id,done);upProg();
}

function upNav(id,done){
  const nc=document.getElementById('nc-'+id);
  const ni=document.querySelector(`.ni[data-t="${id}"]`);
  if(nc)nc.textContent=done?'✓':'';
  if(ni){done?ni.classList.add('done'):ni.classList.remove('done')}
}

function upProg(){
  const done=document.querySelectorAll('.tc.done').length;
  const pct=Math.round(done/21*100);
  const bar=document.getElementById('pbar');
  const lbl=document.getElementById('pct');
  const cnt=document.getElementById('dcnt');
  if(bar)bar.style.width=pct+'%';
  if(lbl)lbl.textContent=done+' / 21';
  if(cnt)cnt.textContent=done;
}

function restore(){
  const s=load();
  Object.entries(s).forEach(([id,done])=>{
    if(done){
      const c=document.getElementById(id);
      if(c){c.classList.add('done');upNav(id,true)}
    }
  });
  upProg();
}

function tab(btn,pid){
  const body=btn.closest('.tb');
  body.querySelectorAll('.ctab').forEach(t=>t.classList.remove('active'));
  body.querySelectorAll('.tp').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  const p=document.getElementById(pid);
  if(p)p.classList.add('active');
}

function cp(btn){
  const v=btn.closest('.cb').querySelector('.cv');
  const text=v.innerText;
  navigator.clipboard.writeText(text).then(()=>{
    btn.textContent='Copiado ✓';btn.classList.add('ok');
    setTimeout(()=>{btn.textContent='Copiar';btn.classList.remove('ok')},2000);
  }).catch(()=>{
    const ta=document.createElement('textarea');ta.value=text;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);
    btn.textContent='Copiado ✓';btn.classList.add('ok');
    setTimeout(()=>{btn.textContent='Copiar';btn.classList.remove('ok')},2000);
  });
}

function go(id){
  const el=document.getElementById(id);
  if(el)el.scrollIntoView({behavior:'smooth',block:'start'});
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  const ni=document.querySelector(`.ni[data-t="${id}"]`);
  if(ni)ni.classList.add('active');
}

// Scroll spy
const cards=document.querySelectorAll('.tc[id]');
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const id=e.target.id;
      document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
      const ni=document.querySelector(`.ni[data-t="${id}"]`);
      if(ni)ni.classList.add('active');
    }
  });
},{threshold:0.5});
cards.forEach(c=>obs.observe(c));

function toggleFab(){document.getElementById('fabm').classList.toggle('open')}
function closeFab(){document.getElementById('fabm').classList.remove('open')}
document.addEventListener('click',e=>{
  const fab=document.querySelector('.fab');
  if(fab&&!fab.contains(e.target))closeFab();
});

restore();
</script>
</body>
</html>
