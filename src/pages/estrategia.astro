<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --ink:#131109;--bg:#f5f2eb;--surface:#fff;--muted:#7a7060;--border:#e2ddd3;--border2:#ede9e1;
  --red:#c8341a;--rd:#c8341a1a;--yel:#f5c840;--yd:#f5c84018;
  --grn:#1e6b3c;--gd:#1e6b3c18;--blu:#1a4f99;--bd:#1a4f9918;
  --pur:#5b2d8c;--pd:#5b2d8c18;--orn:#c96a10;--od:#c96a1018;
  --fh:'Syne',sans-serif;--fb:'Instrument Sans',sans-serif;--fm:'Fira Code',monospace;
}
html{scroll-behavior:smooth;font-size:14px}
body{font-family:var(--fb);background:var(--bg);color:var(--ink);line-height:1.6;overflow-x:hidden}

/* ── SHELL ── */
.shell{display:grid;grid-template-columns:252px 1fr;min-height:100vh}
@media(max-width:900px){.shell{grid-template-columns:1fr}.sidenav{display:none!important}}

/* ── SIDENAV ── */
.sidenav{position:sticky;top:0;height:100vh;overflow-y:auto;background:var(--ink);display:flex;flex-direction:column;scrollbar-width:thin;scrollbar-color:#333 transparent}
.nav-brand{padding:22px 20px 18px;border-bottom:1px solid #ffffff12}
.nav-brand strong{font-family:var(--fh);font-size:13px;font-weight:800;color:var(--yel);display:block}
.nav-brand span{font-size:10px;color:#ffffff35;letter-spacing:2px;text-transform:uppercase;display:block;margin-top:3px}
.nav-prog{padding:12px 20px;border-bottom:1px solid #ffffff12}
.np-row{display:flex;justify-content:space-between;font-size:10px;color:#ffffff35;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}
.np-row strong{color:var(--yel)}
.np-track{height:3px;background:#ffffff15;border-radius:2px;overflow:hidden}
.np-bar{height:100%;background:linear-gradient(90deg,var(--yel),#ffe040);border-radius:2px;width:0%;transition:width .4s ease}
.nsl{padding:14px 20px 5px;font-size:9px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:#ffffff25;display:flex;align-items:center;gap:8px}
.nsl::before{content:'';width:7px;height:7px;border-radius:50%;flex-shrink:0}
.nsl-p::before{background:var(--red)}.nsl-i::before{background:var(--orn)}.nsl-l::before{background:var(--blu)}.nsl-la::before{background:var(--pur)}.nsl-t::before{background:var(--grn)}
.ni{display:flex;align-items:center;gap:10px;padding:7px 20px;font-size:11.5px;color:#ffffff40;cursor:pointer;border-left:2px solid transparent;transition:all .15s;text-decoration:none}
.ni:hover{color:#ffffffaa;background:#ffffff08;border-left-color:#ffffff20}
.ni.active{color:#fff;background:#ffffff0d;border-left-color:var(--yel)}
.ni.done{color:#ffffff28}.ni.done .nic{background:var(--grn);border-color:var(--grn)}
.nic{width:16px;height:16px;min-width:16px;border:1.5px solid #ffffff18;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:9px;color:#fff;font-weight:700;transition:all .2s;flex-shrink:0}
.nid{margin-left:auto;font-family:var(--fm);font-size:9px;color:#ffffff25;white-space:nowrap}
.nav-foot{margin-top:auto;padding:14px 20px;border-top:1px solid #ffffff12;font-size:11px;color:#ffffff35}
.nav-foot strong{color:var(--yel);font-family:var(--fh);font-size:20px;font-weight:800;display:block;line-height:1;margin-bottom:2px}

/* ── MAIN ── */
.main{min-width:0}

/* ── HERO ── */
.hero{background:var(--ink);color:#fff;padding:60px 56px 72px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 420px 280px at 110% 50%,#c8341a20,transparent 70%),repeating-linear-gradient(-45deg,transparent,transparent 30px,#ffffff03 30px,#ffffff03 31px);pointer-events:none}
.hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:44px;background:var(--bg);clip-path:ellipse(52% 100% at 50% 100%)}
.h-tag{display:inline-flex;align-items:center;gap:8px;background:var(--red);color:#fff;font-family:var(--fh);font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;padding:5px 14px;margin-bottom:22px}
.hero h1{font-family:var(--fh);font-size:clamp(38px,5.5vw,66px);font-weight:800;line-height:.92;letter-spacing:-2.5px;margin-bottom:18px;position:relative}
.hero h1 em{font-style:normal;color:var(--yel)}
.h-sub{font-size:15px;color:#b0a898;max-width:540px;line-height:1.75;margin-bottom:38px;position:relative}
.h-stats{display:flex;gap:36px;flex-wrap:wrap;position:relative}
.hs strong{display:block;font-family:var(--fh);font-size:30px;font-weight:800;color:#fff;line-height:1}
.hs span{font-size:10px;color:#ffffff35;text-transform:uppercase;letter-spacing:1.5px;margin-top:3px;display:block}
@media(max-width:600px){.hero{padding:40px 24px 60px}}

/* ── FASE HEADER ── */
.fw{padding:48px 56px 0}
@media(max-width:600px){.fw{padding:32px 24px 0}}
.fh{display:flex;align-items:flex-start;gap:18px;padding-bottom:18px;border-bottom:2px solid var(--border);margin-bottom:18px}
.fbar{width:4px;min-width:4px;border-radius:2px;align-self:stretch}
.fi{flex:1}.fn{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:3px}
.ft{font-family:var(--fh);font-size:clamp(22px,3vw,30px);font-weight:800;letter-spacing:-.5px;line-height:1}
.fd{font-size:12px;color:var(--muted);margin-top:4px;line-height:1.6}
.fc{font-family:var(--fm);font-size:11px;font-weight:500;padding:5px 12px;border-radius:3px;white-space:nowrap;align-self:flex-start;margin-top:4px}

/* ── TASKS ── */
.tw{padding:0 56px;display:flex;flex-direction:column;gap:8px;padding-bottom:8px}
@media(max-width:600px){.tw{padding:0 24px}}
.tc{background:var(--surface);border:1px solid var(--border);position:relative;transition:box-shadow .2s,border-color .2s}
.tc:hover{box-shadow:0 4px 20px rgba(0,0,0,.07)}
.tc.done{opacity:.48}.tc.done .tt-title{text-decoration:line-through;text-decoration-color:var(--muted)}
.tlb{position:absolute;left:0;top:0;bottom:0;width:3px}

/* Card top */
.tt{display:flex;align-items:flex-start;gap:14px;padding:17px 20px 15px;cursor:pointer}
.tcb{width:22px;height:22px;min-width:22px;border:2px solid var(--border);border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0;margin-top:1px;font-size:12px;font-weight:700;color:transparent}
.tc.done .tcb{background:var(--grn);border-color:var(--grn);color:#fff}
.tm{display:flex;align-items:center;gap:7px;margin-bottom:5px;flex-wrap:wrap}
.td-day{font-family:var(--fm);font-size:10px;font-weight:500;background:var(--ink);color:#fff;padding:2px 7px;border-radius:2px;letter-spacing:.5px}
.td-area{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;padding:2px 8px;border-radius:2px}
.td-time{font-family:var(--fm);font-size:10px;color:var(--muted);margin-left:auto}
.tt-title{font-family:var(--fh);font-size:15px;font-weight:700;line-height:1.25;letter-spacing:-.2px;margin-bottom:3px}
