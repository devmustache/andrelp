.tog{margin-left:12px;align-self:flex-start;flex-shrink:0;background:none;border:1px solid var(--border);color:var(--muted);font-family:var(--fb);font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;padding:5px 11px;cursor:pointer;border-radius:3px;transition:all .15s;white-space:nowrap;margin-top:1px}
.tog:hover{background:var(--ink);border-color:var(--ink);color:#fff}

/* Body */
.tb{display:none;border-top:1px solid var(--border2)}
.tb.open{display:block}

/* Tabs */
.ctabs{display:flex;border-bottom:1px solid var(--border2);background:#faf8f4;overflow-x:auto}
.ctab{padding:10px 17px;font-family:var(--fb);font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);border:none;border-bottom:2px solid transparent;background:none;cursor:pointer;white-space:nowrap;transition:all .15s}
