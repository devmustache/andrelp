.cv{background:#0d0d18;color:#c8c8e8;font-family:var(--fm);font-size:12px;line-height:1.9;padding:16px 20px;border-radius:0 0 3px 3px;white-space:pre-wrap;word-break:break-word;overflow-x:auto;max-height:400px;overflow-y:auto}

/* Metrics table */
.mt{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px}
.mt th{background:#f0ece2;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:8px 12px;text-align:left;color:var(--muted);border-bottom:1px solid var(--border)}
.mt td{padding:8px 12px;border-bottom:1px solid var(--border2);vertical-align:top;line-height:1.5}
.mt tr:last-child td{border-bottom:none}
.mg{color:var(--grn);font-weight:700}.mw{color:var(--red);font-weight:700}.mc{color:var(--orn);font-weight:700}

/* Checklist */
.chl{display:flex;flex-direction:column;gap:6px}
.chi{display:flex;align-items:flex-start;gap:10px;font-size:12.5px;line-height:1.5}
.chi::before{content:'☐';flex-shrink:0;font-size:14px;color:var(--muted)}

/* Spacer / pad */
.sp{height:44px}.bp{height:80px}

/* Float button */
.fab{position:fixed;bottom:24px;right:24px;z-index:200}
.fab-btn{width:50px;height:50px;background:var(--ink);border:none;border-radius:50%;color:#fff;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,.25);transition:background .2s,transform .15s}
.fab-btn:hover{background:var(--red);transform:scale(1.05)}
.fab-menu{position:absolute;bottom:60px;right:0;background:var(--ink);border:1px solid #ffffff15;min-width:250px;border-radius:4px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,.3);display:none}
.fab-menu.open{display:block}
.fam-hd{padding:11px 16px 7px;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#ffffff30;border-bottom:1px solid #ffffff12}
.fam-l{display:block;padding:9px 16px;font-size:12px;color:#b0a898;cursor:pointer;text-decoration:none;transition:background .15s,color .15s;border-left:2px solid transparent}
.fam-l:hover{background:#ffffff0d;color:#fff;border-left-color:var(--yel)}
.fam-l span{display:block;font-size:10px;color:#ffffff28;margin-top:1px}
</style>
</head>
